{
  "name": "authenik8-core",
  "version": "2.0.1",
  "description": "A JOSE/JWK identity engine with agent identities, rotating ES256 keys, stateful sessions, and secure refresh rotation.",
  "keywords": [
    "authentication",
    "jwt",
    "rate-limiter",
    "api-security",
    "redis",
    "express",
    "nodejs",
    "auth",
    "ai-agent",
    "machine-identity",
    "backend",
    "helmet"
  ],
  "homepage": "https://gitlab.com/COD434/authenik8-core#readme",
  "bugs": {
    "url": "https://gitlab.com/COD434/authenik8-core/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/COD434/authenik8-core.git"
  },
  "license": "MIT",
  "author": "Karabo Seeisa",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": "^20.19 || ^22.12 || >=24"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:ci": "vitest run --config vitest.config.ts --coverage --coverage.reportOnFailure --coverage.reporter=text-summary --coverage.reporter=lcov --coverage.reporter=cobertura --coverage.reportsDirectory=coverage/unit --reporter=default --reporter=junit --outputFile=reports/unit/junit.xml",
    "test:integration": "vitest run --config vitest.integration.config.ts --no-file-parallelism",
    "test:integration:ci": "vitest run --config vitest.integration.config.ts --no-file-parallelism --coverage --coverage.reportOnFailure --coverage.reporter=text-summary --coverage.reporter=lcov --coverage.reporter=cobertura --coverage.reportsDirectory=coverage/integration --reporter=default --reporter=junit --outputFile=reports/integration/junit.xml",
    "test:matrix": "vitest run --config vitest.config.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "ioredis-mock": "^8.13.1",
    "jsonwebtoken": "^9.0.3",
    "node-mocks-http": "^1.17.2",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.44.1",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "connect-redis": "^9.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "ip-address": "^10.2.0",
    "jose": "^6.2.3",
    "rate-limiter-flexible": "^10.0.1"
  }
}
