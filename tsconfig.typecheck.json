{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "src/**/*.ts",
    "vitest.config.ts",
    "vitest.integration.config.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "src/tests/oauth1.test.ts",
    "src/tests/oauth2.test.ts",
    "src/tests/oauth3.test.ts"
  ]
}
